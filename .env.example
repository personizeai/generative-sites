# ─── Personize SDK (required for setup and seed scripts) ────────────────────
PERSONIZE_SECRET_KEY=sk_live_YOUR_SECRET_KEY

# ─── GS Collection ──────────────────────────────────────────────────────────
# Slug of the Personize collection used for property zones.
# Default: website_zones
# GS_COLLECTION_SLUG=website_zones

# ─── Rate Limiting ──────────────────────────────────────────────────────────
# Pause (ms) between batched API calls during seed/setup. Default: 2000
# RATE_LIMIT_PAUSE_MS=2000
